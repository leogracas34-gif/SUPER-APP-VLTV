<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/player_bg">

    <!-- ExoPlayer Surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:use_controller="false"
        app:surface_type="surface_view"
        app:resize_mode="fit"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Buffering Indicator -->
    <ProgressBar
        android:id="@+id/progress_buffering"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:indeterminateTint="@color/vltv_blue"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible" />

    <!-- Error Message -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:background="#80000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Erro de reprodução" />

    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/gradient_player_top"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/PlayerControlButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconSize="24dp"
            android:contentDescription="@string/back" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Nome do Filme" />

        <!-- PiP Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pip"
            style="@style/PlayerControlButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:icon="@drawable/ic_pip"
            app:iconSize="20dp"
            android:contentDescription="Picture in Picture"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ===== BOTTOM CONTROLS ===== -->
    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:background="@drawable/gradient_player_bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Time labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="00:00" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="01:30:00" />
        </LinearLayout>

        <!-- SeekBar -->
        <SeekBar
            android:id="@+id/seek_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="@color/seekbar_progress"
            android:progressBackgroundTint="@color/progress_track"
            android:thumbTint="@color/vltv_blue"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Playback Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Rewind 10s -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_rewind"
                style="@style/PlayerControlButton"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                app:icon="@drawable/ic_replay_10"
                app:iconSize="28dp"
                android:visibility="gone" />

            <!-- Play / Pause -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_play_pause"
                style="@style/PlayerControlButton"
                android:layout_width="@dimen/player_control_size_lg"
                android:layout_height="@dimen/player_control_size_lg"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:icon="@drawable/ic_pause"
                app:iconSize="36dp" />

            <!-- Forward 10s -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_forward"
                style="@style/PlayerControlButton"
                android:layout_width="@dimen/player_control_size"
                android:layout_height="@dimen/player_control_size"
                app:icon="@drawable/ic_forward_10"
                app:iconSize="28dp"
                android:visibility="gone" />

        </LinearLayout>
    </LinearLayout>

    <!-- ===== SKIP INTRO BUTTON (bottom right) ===== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_skip_intro"
        style="@style/VLTVButton.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="@string/skip_intro"
        android:textSize="14sp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="100dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible" />

    <!-- ===== NEXT EPISODE BUTTON (bottom right) ===== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_next_episode"
        style="@style/VLTVButton.Icon"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="@string/next_episode"
        android:textSize="14sp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="100dp"
        android:visibility="gone"
        app:icon="@drawable/ic_skip_next"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:visibility="visible" />

</androidx.constraintlayout.widget.ConstraintLayout>
