<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="10dp"
    android:focusable="true"
    android:clickable="true"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Episode Thumbnail -->
        <androidx.cardview.widget.CardView
            android:layout_width="140dp"
            android:layout_height="80dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/iv_thumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/shimmer_base"
                android:contentDescription="@null" />

            <!-- Episode Number badge -->
            <TextView
                android:id="@+id/tv_episode_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:background="#CC000000"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                tools:text="E1" />

            <!-- Watch progress bar -->
            <ProgressBar
                android:id="@+id/progress_watched"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_gravity="bottom"
                android:progressTint="@color/vltv_blue"
                android:progressBackgroundTint="@color/transparent"
                android:max="100"
                android:visibility="gone" />

        </androidx.cardview.widget.CardView>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Nome do Episódio" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                tools:text="45min" />

            <TextView
                android:id="@+id/tv_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginTop="4dp"
                tools:text="Sinopse do episódio. Lorem ipsum dolor sit amet." />

        </LinearLayout>

        <!-- Play Icon -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_play"
            android:tint="@color/text_tertiary"
            android:layout_gravity="center"
            android:contentDescription="@null" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
