<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Category Sidebar (left) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_categories"
        android:layout_width="@dimen/sidebar_width"
        android:layout_height="0dp"
        android:background="@color/nav_bg"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:listitem="@layout/item_category" />

    <!-- Main content (right of sidebar) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/rv_categories"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Mini Player (top right, visible on TV when channel focused) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layout_mini_player"
            android:layout_width="@dimen/mini_player_width"
            android:layout_height="@dimen/mini_player_height"
            android:layout_margin="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/player_bg"
            app:cardCornerRadius="10dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.media3.ui.PlayerView
                    android:id="@+id/mini_player_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:use_controller="false"
                    app:surface_type="surface_view"
                    app:resize_mode="fill" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_expand_player"
                    style="@style/PlayerControlButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="4dp"
                    app:icon="@drawable/ic_skip_next"
                    app:iconSize="18dp" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- EPG below mini player -->
        <LinearLayout
            android:id="@+id/layout_epg"
            android:layout_width="@dimen/mini_player_width"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layout_mini_player"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:padding="4dp"
                tools:text="Canal de TV" />

            <TextView
                android:id="@+id/tv_current_program"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/vltv_accent"
                android:textSize="12sp"
                android:padding="4dp"
                tools:text="Programa Atual" />

            <TextView
                android:id="@+id/tv_program_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:paddingStart="4dp"
                android:paddingBottom="4dp"
                tools:text="20:00 - 21:00" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_epg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_epg" />
        </LinearLayout>

        <!-- Channels list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_channels"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:paddingTop="8dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/layout_mini_player"
            tools:listitem="@layout/item_channel" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
